# ---------------------------------------------------------------------------
# CurriePing configuration.  Copy to `.env` and edit TARGETS.
# ---------------------------------------------------------------------------

# Public hostname (informational + Caddy LE if you publish proxy directly).
# With Cloudflare Tunnel (recommended), TLS is at Cloudflare; leave this blank
# or set it to the same hostname you attach to the tunnel for clarity.
STATUS_DOMAIN=

# Heading shown at the top of the page.
STATUS_TITLE=Service Status

# Sites to monitor: comma-separated  Name=URL  pairs, where Name is the display
# label (e.g. example.com=https://example.com). A bare URL also
# works and is labelled by its hostname.
# A site is "up" when every probed address family returns HTTP status < 400.
TARGETS=google.com=https://www.google.com,microsoft.com=https://www.microsoft.com

# Address-family probes. IPv6 is always checked. IPv4 needs public IPv4 egress
# on the host (e.g. an AWS Elastic IP, ~$3.65/mo). On a cheap IPv6-only EC2
# set False — the status page shows unchecked IPv4 / checked IPv6.
# Must be exactly True or False (required; any other value fails startup).
CHECK_IPV4=False

# How often (seconds) each target is probed.
CHECK_INTERVAL_SECONDS=60

# Per-request timeout (seconds).
REQUEST_TIMEOUT_SECONDS=10

# How many days of history the thin bars show.
HISTORY_DAYS=90

# Alerting via ntfy (optional). On down/recovery a notification is POSTed to
# this full topic URL; subscribe to it in the ntfy phone app. It can point at
# the public ntfy.sh or your own self-hosted ntfy server — it's the whole URL,
# host included. The topic name is the only secret, so make it unguessable.
# Blank -> alerting disabled.
# ALERT_FAIL_THRESHOLD = consecutive failures required before a "down" alert.
NTFY_URL=https://ntfy.sh/your-unguessable-topic-name
ALERT_FAIL_THRESHOLD=2

# --- Cloudflare Tunnel (recommended for AWS: IPv4 visitors, no public IPv4) ---
# 1. Zero Trust → Networks → Tunnels → Create → Docker → copy the token.
# 2. Public hostname: STATUS_DOMAIN → http://app:8080  (docker service name).
# 3. DNS: CNAME STATUS_DOMAIN → <tunnel-id>.cfargotunnel.com  (or let Cloudflare
#    manage the record if the zone is on Cloudflare).
# 4. Set COMPOSE_PROFILES=tunnel so `docker compose up` starts cloudflared.
COMPOSE_PROFILES=
CLOUDFLARE_TUNNEL_TOKEN=
