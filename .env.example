# ---------------------------------------------------------------------------
# status_monitor configuration.  Copy to `.env` and edit TARGETS.
# ---------------------------------------------------------------------------

# Public hostname for the status page. When set, Caddy auto-provisions an
# HTTPS certificate from Let's Encrypt (the DNS A-record must already point at
# this server). Leave BLANK to serve plain HTTP on port 80 (local testing).
STATUS_DOMAIN=

# Heading shown at the top of the page.
STATUS_TITLE=Service Status

# Sites to monitor: comma-separated  Name=URL  pairs, where Name is the display
# label (e.g. example.com=https://example.com). A bare URL also
# works and is labelled by its hostname.
# A site is "up" when it returns any HTTP status below 400 within the timeout.
TARGETS=google.com=https://www.google.com,microsoft.com=https://www.microsoft.com

# How often (seconds) each target is probed.
CHECK_INTERVAL_SECONDS=60

# Per-request timeout (seconds).
REQUEST_TIMEOUT_SECONDS=10

# How many days of history the thin bars show.
HISTORY_DAYS=90
